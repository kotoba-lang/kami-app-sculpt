(ns kami.sculpt.ui (:require [html.core :as html] [css.core :as css]))
(def sheet {:rules {"*" {:box-sizing :border-box} "body" {:margin 0 :height "100vh" :display :grid :grid-template-rows "52px 1fr" :font-family "Inter,system-ui" :background "#17131d" :color "#f7efff"} "header" {:display :flex :align-items :center :gap 18 :padding "0 16px" :background "#2a2034"} "header .spacer" {:flex 1} "main" {:display :grid :grid-template-columns "240px 1fr 250px" :min-height 0} "aside" {:padding 16 :background "#21192a" :border-right "1px solid #51375e"} "aside:last-child" {:border-left "1px solid #51375e" :border-right 0} ".viewport" {:position :relative} "#gpu-canvas" {:width "100%" :height "100%" :display :block :cursor :crosshair} "#gpu-status" {:position :absolute :left "50%" :top "45%" :transform "translate(-50%,-50%)" :color "#ffb0b0"} "button,input,select" {:width "100%" :margin "5px 0" :padding 9 :background "#51375e" :color "#fff" :border "1px solid #a87eb5" :border-radius 6} "button" {:cursor :pointer :text-align :left} ".selected,.primary" {:background "#d18ab9" :color "#271225" :font-weight 700} "h2" {:font-size 11 :letter-spacing ".12em" :text-transform :uppercase :color "#d6afd8"} "label" {:display :grid :gap 5 :margin "12px 0"} ".stats" {:position :absolute :right 14 :bottom 14 :background "#170d1dcc" :padding 8}}})
(defn page [] (html/html5 [:html {:lang "en"} [:head [:meta {:charset "utf-8"}] [:meta {:name "viewport" :content "width=device-width,initial-scale=1"}] [:link {:rel "icon" :href "data:,"}] [:title "Kami Sculpt"] [:style (css/css sheet)]] [:body [:header [:strong "KAMI SCULPT · DIGITAL CLAY"] [:a {:href "https://kotoba-lang.github.io/kami-studio/"} "Studio"] [:span "WebGPU brush workspace"] [:span.spacer] [:button {:id "undo"} "Undo stroke"] [:button {:id "redo"} "Redo"] [:button {:id "export"} "Export EDN"]] [:main [:aside [:h2 "Brushes"] [:button.selected {:data-mode "inflate"} "Inflate"] [:button {:data-mode "smooth"} "Smooth"] [:button {:data-mode "pinch"} "Pinch"] [:button {:data-mode "mask"} "Mask"] [:button {:data-mode "mask-erase"} "Erase mask"] [:h2 "Mask"] [:button {:id "clear-mask"} "Clear mask"] [:button {:id "invert-mask"} "Invert mask"] [:h2 "Symmetry"] [:label [:input {:id "symmetry-x" :type "checkbox" :checked true}] "X mirror"] [:label [:input {:id "symmetry-y" :type "checkbox"}] "Y mirror"] [:label [:input {:id "symmetry-z" :type "checkbox"}] "Z mirror"]] [:section.viewport [:canvas {:id "gpu-canvas" :aria-label "Sculpt WebGPU viewport"}] [:div {:id "gpu-status"} "Initializing WebGPU…"] [:div.stats {:id "stats"} "153 vertices · 256 triangles · 0 strokes"]] [:aside [:h2 "Brush settings"] [:label "Radius" [:output {:id "radius-value"} "0.60"] [:input {:id "radius" :type "range" :min 0.1 :max 1.5 :step 0.05 :value 0.6}]] [:label "Strength" [:output {:id "strength-value"} "0.12"] [:input {:id "strength" :type "range" :min -0.3 :max 0.3 :step 0.01 :value 0.12}]] [:label "Stroke spacing" [:input {:id "spacing" :type "range" :min 0.02 :max 0.5 :step 0.01 :value 0.12}]] [:h2 "Topology"] [:button.primary {:id "subdivide"} "Subdivide mesh"] [:p "Shared-edge refinement preserves mask values and enables finer detail."]]] [:span {:id "debug-state" :style {:display "none"}}] [:script {:src "./js/app.js"}]]]))
